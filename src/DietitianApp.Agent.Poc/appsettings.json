{
  "App": {
    "WhatsAppUrl": "https://web.whatsapp.com/",
    "UserDataDirectory": "./.profile/whatsapp",
    "ScreenshotsDirectory": "./artifacts/screenshots",
    "TracesDirectory": "./artifacts/traces",
    "NavigationTimeoutSeconds": 60,
    "LoginTimeoutSeconds": 180,
    "ActionTimeoutSeconds": 20,
    "Headless": false
  },
  "WhatsAppSelectors": {
    "CaptchaIndicators": [
      "text=captcha",
      "text=CAPTCHA",
      "text=robot"
    ],
    "SearchBoxSelectors": [
      "div[role='textbox'][contenteditable='true'][aria-label*='Search']",
      "div[role='textbox'][contenteditable='true'][aria-label*='Ara']",
      "div[contenteditable='true'][data-tab='3']"
    ],
    "ChatTitleSelector": "header span[title]",
    "MessageBoxSelectors": [
      "footer div[role='textbox'][contenteditable='true'][aria-label*='message']",
      "footer div[role='textbox'][contenteditable='true'][aria-label*='mesaj']",
      "footer div[contenteditable='true']"
    ],
    "LoginReadySelectors": [
      "div[role='textbox'][contenteditable='true'][aria-label*='Search']",
      "div[role='textbox'][contenteditable='true'][aria-label*='Ara']",
      "div[contenteditable='true'][data-tab='3']"
    ],
    "QrLoginSelectors": [
      "canvas[aria-label*='Scan']",
      "canvas",
      "text=Use WhatsApp on your computer",
      "text=WhatsApp Web"
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "./logs/agent-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}

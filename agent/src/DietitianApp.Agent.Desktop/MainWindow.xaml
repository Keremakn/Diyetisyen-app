<Window x:Class="DietitianApp.Agent.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Diyetisyen App Agent"
        Width="1220"
        Height="780"
        MinWidth="980"
        MinHeight="640"
        Background="#F5F7FA">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Background="#203A43">
            <TextBlock Text="Diyetisyen App" Foreground="White" FontSize="22" FontWeight="SemiBold" Margin="20,24"/>
            <ListBox SelectedIndex="{Binding SelectedPageIndex}" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="15">
                <ListBoxItem Content="Dashboard"/>
                <ListBoxItem Content="Gruplar"/>
                <ListBoxItem Content="Mesaj Sablonlari"/>
                <ListBoxItem Content="Yeni Gonderim"/>
                <ListBoxItem Content="Gonderim Gecmisi"/>
                <ListBoxItem Content="Ayarlar / WhatsApp"/>
            </ListBox>
        </StackPanel>

        <Grid Grid.Column="1" Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="{Binding CurrentPage}" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,18"/>

            <TabControl Grid.Row="1" SelectedIndex="{Binding SelectedPageIndex}">
                <TabItem Header="Dashboard">
                    <StackPanel Margin="20">
                        <TextBlock Text="Agent durumu" FontSize="20"/>
                        <TextBlock Text="Gruplari, sablonlari ve son gonderimleri sol menuden yonetin." Margin="0,12"/>
                        <Button Content="Verileri Yenile" Command="{Binding RefreshCommand}" Width="140" HorizontalAlignment="Left"/>
                    </StackPanel>
                </TabItem>

                <TabItem Header="Gruplar">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="320"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid ItemsSource="{Binding Groups}"
                                  SelectedItem="{Binding SelectedGroup}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Margin="4">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Gorunen ad" Binding="{Binding Group.DisplayName}" Width="*"/>
                                <DataGridTextColumn Header="WhatsApp tam adi" Binding="{Binding Group.ExternalName}" Width="*"/>
                                <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding Group.IsActive}" Width="70"/>
                                <DataGridCheckBoxColumn Header="Dogrulandi" Binding="{Binding Group.IsVerified}" Width="90"/>
                                <DataGridTextColumn Header="Durum" Binding="{Binding State}" Width="120"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Column="1" Background="White" Padding="14" Margin="12,4,4,4" BorderBrush="#D9E1E8" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Grup Duzenle" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock Text="WhatsApp tam grup adi"/>
                                <TextBox Text="{Binding ExternalName,UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10"/>
                                <TextBlock Text="Uygulamada gorunen ad"/>
                                <TextBox Text="{Binding DisplayName,UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,14"/>
                                <Button Content="WhatsApp'ta Dogrula ve Kaydet" Command="{Binding SaveGroupCommand}" Margin="0,0,0,8"/>
                                <Button Content="Secili Grubu Yeniden Dogrula" Command="{Binding VerifySelectedGroupCommand}" Margin="0,0,0,8"/>
                                <Button Content="Aktif / Pasif Degistir" Command="{Binding ToggleGroupActiveCommand}" Margin="0,0,0,8"/>
                                <Button Content="Yeni Grup" Command="{Binding NewGroupCommand}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Mesaj Sablonlari">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="360"/>
                        </Grid.ColumnDefinitions>

                        <DataGrid ItemsSource="{Binding Templates}"
                                  SelectedItem="{Binding SelectedTemplateForEdit}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Margin="4">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Ad" Binding="{Binding Name}" Width="220"/>
                                <DataGridTextColumn Header="Icerik onizleme" Binding="{Binding Content}" Width="*"/>
                                <DataGridCheckBoxColumn Header="Aktif" Binding="{Binding IsActive}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Column="1" Background="White" Padding="14" Margin="12,4,4,4" BorderBrush="#D9E1E8" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="Sablon Duzenle" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                                <TextBlock Text="Sablon adi"/>
                                <TextBox Text="{Binding TemplateName,UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10"/>
                                <TextBlock Text="Mesaj icerigi"/>
                                <TextBox Text="{Binding TemplateContent,UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="230" TextWrapping="Wrap" Margin="0,4,0,14"/>
                                <Button Content="Sablonu Kaydet" Command="{Binding SaveTemplateCommand}" Margin="0,0,0,8"/>
                                <Button Content="Aktif / Pasif Degistir" Command="{Binding ToggleTemplateActiveCommand}" Margin="0,0,0,8"/>
                                <Button Content="Yeni Sablon" Command="{Binding NewTemplateCommand}"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="Yeni Gonderim">
                    <Grid Margin="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Tumunu sec" Command="{Binding SelectAllCommand}" Margin="2"/>
                                <Button Content="Secimi kaldir" Command="{Binding ClearSelectionCommand}" Margin="2"/>
                                <TextBlock Text="{Binding SelectedCount,StringFormat=Secili: {0}}" Margin="12,7"/>
                            </StackPanel>
                            <ItemsControl ItemsSource="{Binding Groups}" Margin="0,8,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected}"
                                                  IsEnabled="{Binding CanSend}"
                                                  Content="{Binding Group.DisplayName}"
                                                  Margin="4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <ComboBox ItemsSource="{Binding ActiveTemplates}" SelectedItem="{Binding SelectedTemplate}" DisplayMemberPath="Name" Margin="4"/>
                            <TextBox Text="{Binding Message,UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="240" TextWrapping="Wrap" Margin="4"/>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Gonderimi Baslat" Command="{Binding SendCommand}" Margin="4"/>
                                <Button Content="Iptal" Command="{Binding CancelCommand}" Margin="4"/>
                            </StackPanel>
                            <ProgressBar Value="{Binding ProgressValue}" Height="18" Margin="4"/>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="Gonderim Gecmisi">
                    <Grid Margin="16">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="2*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DataGrid ItemsSource="{Binding History}"
                                  SelectedItem="{Binding SelectedHistory}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Margin="4">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Tarih" Binding="{Binding CreatedAtUtc}" Width="170"/>
                                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="150"/>
                                <DataGridTextColumn Header="Toplam" Binding="{Binding TotalCount}" Width="80"/>
                                <DataGridTextColumn Header="Basarili" Binding="{Binding SuccessCount}" Width="80"/>
                                <DataGridTextColumn Header="Hatali" Binding="{Binding FailureCount}" Width="80"/>
                                <DataGridTextColumn Header="Iptal" Binding="{Binding CancelledCount}" Width="80"/>
                                <DataGridTextColumn Header="Mesaj" Binding="{Binding MessageContent}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4,8">
                            <Button Content="Basarisizlari Yeniden Dene" Command="{Binding RetryFailuresCommand}" Margin="0,0,8,0"/>
                            <Button Content="Hatali ve Iptal Edilenleri Yeniden Dene" Command="{Binding RetryUnsuccessfulCommand}" Margin="0,0,8,0"/>
                            <Button Content="Yenile" Command="{Binding RefreshCommand}"/>
                        </StackPanel>

                        <DataGrid Grid.Row="2"
                                  ItemsSource="{Binding HistoryItems}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  Margin="4">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Grup" Binding="{Binding GroupNameSnapshot}" Width="170"/>
                                <DataGridTextColumn Header="Durum" Binding="{Binding Status}" Width="110"/>
                                <DataGridTextColumn Header="Deneme" Binding="{Binding AttemptCount}" Width="80"/>
                                <DataGridTextColumn Header="Hata Kodu" Binding="{Binding ErrorCode}" Width="130"/>
                                <DataGridTextColumn Header="Hata Mesaji" Binding="{Binding ErrorMessage}" Width="*"/>
                                <DataGridTextColumn Header="Screenshot" Binding="{Binding ScreenshotPath}" Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </TabItem>

                <TabItem Header="Ayarlar / WhatsApp">
                    <StackPanel Margin="20">
                        <TextBlock Text="WhatsApp Web baglantisi" FontSize="20"/>
                        <Button Content="Baglantiyi Kontrol Et / QR Ac" Command="{Binding VerifyConnectionCommand}" Width="220" HorizontalAlignment="Left" Margin="0,14"/>
                        <TextBlock Text="Ilk kullanimda acilan Chromium penceresinde QR kodunu telefonunuzla tarayin." TextWrapping="Wrap"/>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <Border Grid.Row="2" Background="White" Padding="10" Margin="0,12,0,0">
                <TextBlock Text="{Binding Status}"/>
            </Border>
        </Grid>
    </Grid>
</Window>
